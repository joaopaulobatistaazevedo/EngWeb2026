extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h2 Detalhes do Filme

    .w3-container.w3-padding

      p
        b Título:
        |  #{filme.title}

      p
        b Ano:
        |  #{filme.year}

      p
        b Géneros:
        |  #{filme.genres ? filme.genres.join(', ') : 'N/A'}

      p
        b Elenco:

      ul.w3-ul.w3-card-4
        each a in filme.cast
          li= a

      br
      a.w3-btn.w3-grey(href="/filmes") Voltar
