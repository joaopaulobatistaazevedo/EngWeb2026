extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h2 Detalhes do Ator

    .w3-container.w3-padding

      p
        b Nome:
        |  #{ator.nome}

      p
        b Nº de Filmes:
        |  #{filmesInfo.length}

      ul.w3-ul.w3-card-4
        each f in filmesInfo
          li
            a(href=`/filmes/${f._id}`) #{f.title} (#{f.year})

      br
      a.w3-btn.w3-grey(href="/atores") Voltar
