extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Lista de Atores

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th ID
          th Nome
          th Nº Filmes

        each a in atores
          tr(onclick=`window.location='/atores/${a._id}'` style="cursor:pointer")
            td= a._id
            td= a.nome
            td= a.filmes ? a.filmes.length : 0
