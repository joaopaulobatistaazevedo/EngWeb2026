extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Lista de Filmes

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th ID
          th Título
          th Ano
          th Nº Atores
          th Nº Géneros

        each f in filmes
          tr(onclick=`window.location='/filmes/${f._id}'` style="cursor:pointer")
            td= f.id || f._id
            td= f.title
            td= f.year
            td= f.cast ? f.cast.length : 0
            td= f.genres ? f.genres.length : 0
