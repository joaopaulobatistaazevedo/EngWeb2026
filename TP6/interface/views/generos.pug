extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Lista de Géneros

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th ID
          th Designação
          th Nº Filmes

        each g in generos
          tr
            td= g._id
            td= g.designacao
            td= g.filmes ? g.filmes.length : 0
