extends layout

block content
  .w3-card-4
    header.w3-container.w3-indigo
      h1  Géneros

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Género
          th Nº de Filmes

        each g in list
          tr(onclick=`window.location='/generos/${g.id}'` style="cursor:pointer")
            td= g.nome
            td= g.filmes.length