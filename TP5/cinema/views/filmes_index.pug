extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1  Lista de Filmes

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Título
          th Ano
          th Géneros

        each f in list
          tr(onclick=`window.location='/filmes/${f.id}'` style="cursor:pointer")
            td= f.title
            td= f.year
            td= f.genres.map(g => g.nome).join(', ')