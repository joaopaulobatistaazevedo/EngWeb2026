extends layout

block content
  .w3-card-4
    header.w3-container.w3-purple
      h1  Lista de Atores

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Nome
          th Nº de Filmes

        each a in list
          tr(onclick=`window.location='/atores/${a.id}'` style="cursor:pointer")
            td= a.nome
            td= a.filmes.length